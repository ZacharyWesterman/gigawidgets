<?xml version="1.0"?>
<!DOCTYPE body SYSTEM "../../tools/xmltree/gigawidgets.dtd">
<body color="#254" rotation="90">
    <column size="100vw 100vh">
        <row size="100vw 75vh">
            <!-- Album Art -->
            <panel size="50vw 75vh" color="#4a8">
                <image align="center center" source="image" />
            </panel>
            <!-- Song/Artist/Album details -->
            <column size="50vw 50vh" align="right center" padding="0.2cm 0">
                <text font="FreeSerifBold24pt7b">Song Name</text>
                <text font="FreeSerif18pt7b">Album Name</text>
                <text font="FreeSerif18pt7b">Artist Name</text>
                <text font="FreeSerif18pt7b">1/20</text>

                <!-- Play/Pause text. Wrapped in a panel to reduce flickering when re-rendering. -->
                <panel size="30vw 10vh" color="#254">
                    <text id="status" font="FreeSerif18pt7b" color="gray">Paused</text>
                </panel>
            </column>
        </row>

        <!-- Controls -->
        <panel size="100vw 25vh" color="#386">
            <row size="69vw 25vh" padding="5px" align="center center">
                <image source="backward_fast" onpress="mark" onrelease="unmark" />
                <image source="backward" onpress="mark" onrelease="unmark" />
                <image source="play" onpress="mark" onrelease="toggle_player" />
                <image source="forward" onpress="mark" onrelease="unmark" />
                <image source="forward_fast" onpress="mark" onrelease="unmark" />
            </row>
        </panel>
    </column>
</body>
 
