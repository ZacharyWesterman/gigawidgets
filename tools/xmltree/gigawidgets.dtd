<!-- 
    DTD for GigaWidgets XML Parser
    Defines all valid XML elements and attributes supported by the xmltree parser
    Generated from parser analysis
-->

<!-- Root element: exactly one widget -->
<!ELEMENT body (collection | column | row | panel | blink | text | input | image | keyboard)>
<!ATTLIST body
    color CDATA #IMPLIED
    rotation (0 | 90 | 180 | 270) #IMPLIED
    padding CDATA #IMPLIED
    class CDATA #IMPLIED
    onclick CDATA #IMPLIED
    onblur CDATA #IMPLIED
    onpress CDATA #IMPLIED
    onrelease CDATA #IMPLIED
    onhold CDATA #IMPLIED
    id CDATA #IMPLIED
>

<!-- Container: Collection - can contain any widgets -->
<!ELEMENT collection (collection | column | row | panel | blink | text | input | image | keyboard)*>
<!ATTLIST collection
    pos CDATA #IMPLIED
    align CDATA #IMPLIED
    padding CDATA #IMPLIED
    size CDATA #REQUIRED
    class CDATA #IMPLIED
    onclick CDATA #IMPLIED
    onblur CDATA #IMPLIED
    onpress CDATA #IMPLIED
    onrelease CDATA #IMPLIED
    onhold CDATA #IMPLIED
    id CDATA #IMPLIED
>

<!-- Container: Column - can contain any widgets -->
<!ELEMENT column (collection | column | row | panel | blink | text | input | image | keyboard)*>
<!ATTLIST column
    pos CDATA #IMPLIED
    align CDATA #IMPLIED
    padding CDATA #IMPLIED
    size CDATA #REQUIRED
    order (top | bottom | top-down | bottom-up) #IMPLIED
    height CDATA #IMPLIED
    class CDATA #IMPLIED
    onclick CDATA #IMPLIED
    onblur CDATA #IMPLIED
    onpress CDATA #IMPLIED
    onrelease CDATA #IMPLIED
    onhold CDATA #IMPLIED
    id CDATA #IMPLIED
>

<!-- Container: Row - can contain any widgets -->
<!ELEMENT row (collection | column | row | panel | blink | text | input | image | keyboard)*>
<!ATTLIST row
    pos CDATA #IMPLIED
    align CDATA #IMPLIED
    padding CDATA #IMPLIED
    size CDATA #REQUIRED
    order (left | right | left-to-right | right-to-left) #IMPLIED
