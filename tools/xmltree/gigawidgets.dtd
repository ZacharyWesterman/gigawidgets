<!-- 
    ATTRIBUTE VALUE FORMATS:
    
    color: Named colors (white, black, red, green, blue, etc.) or hex format (#RGB or #RRGGBB)
           Valid named colors: white, black, gray, red, orange, yellow, green, cyan, blue, purple, magenta, 
                               light-gray, light-red, light-orange, light-yellow, light-green, light-cyan, 
                               light-blue, pink
    
    pos/align: Space-separated pair of Position values (numeric -1.0 to 1.0) or alignment keywords
               Alignment: "left|center|right top|center|bottom"
    
    size: Numeric value with unit (px, vw, vh, in, cm, mm) or just numeric (defaults to px)
          Examples: "100px", "50", "10cm", "5in"
    
    padding: 1, 2, or 4 space-separated size values
             Examples: "10", "10 20", "10 20 30 40"
    
    scale: Integer scale factor for text size
    
    time: Number with time unit (ms, milli, s, sec, m, min, h, hr, d, dy, days)
          Examples: "500ms", "1s", "30sec", "2min", "1hr"
    
    value: String text content for input elements
    
    rotation: 0, 90, 180, or 270 degrees
    
    order: Vertical ordering (TOP, BOTTOM, TOP-DOWN, BOTTOM-UP)
           Horizontal ordering (LEFT, RIGHT, LEFT-TO-RIGHT, RIGHT-TO-LEFT)
    
    class: Space-separated list of CSS class names for styling
-->
