    onclick CDATA #IMPLIED
    onblur CDATA #IMPLIED
    onpress CDATA #IMPLIED
    onrelease CDATA #IMPLIED
    onhold CDATA #IMPLIED
    id CDATA #IMPLIED
>

<!-- Container: Panel - exactly one child widget with background -->
<!ELEMENT panel (collection | column | row | panel | blink | text | input | image | keyboard)>
<!ATTLIST panel
    pos CDATA #IMPLIED
    align CDATA #IMPLIED
    padding CDATA #IMPLIED
    color CDATA #IMPLIED
    size CDATA #IMPLIED
